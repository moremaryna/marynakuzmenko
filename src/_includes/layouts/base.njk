<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ site.title }}</title>
  <meta name="description" content="{{ site.description }}" />
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body>
  <header class="site-header">
    <div class="header-container">
      <a href="/" class="logo">
        {{ site.title }}<span class="dot">.</span>
      </a>

      <input type="checkbox" id="nav-toggle" class="nav-toggle">
      <label for="nav-toggle" class="nav-toggle-label">
        <span></span>
      </label>

      <nav class="nav">
      <ul>
        <li><a href="/services/">Services</a></li>
        <li><a href="/events/">Events</a></li>
        <li><a href="/speaking/">Speaking</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
      </ul>
      </nav>
    </div>
  </header>

  <main class="main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__brand">
        <div class="brand">Dr. Maryna Kuzmenko</div>
        <p class="footer__tagline">Architecting the future of agrifood through AI, Education, Policy, and Human-First Innovation.</p>
        <div class="footer__social-links">
          {% if site.social.linkedin %}<a href="{{ site.social.linkedin }}" aria-label="LinkedIn">LinkedIn</a>{% endif %}
          {% if site.social.youtube %}<a href="{{ site.social.youtube }}" aria-label="YouTube">YouTube</a>{% endif %}
        </div>
      </div>

      <div class="footer__grid">
        <div class="footer__col">
          <span class="footer__label">Expertise</span>
          <a href="/speaking/">Keynotes & Lectures</a>
          <a href="/events/">Events</a>
          <a href="/services/">Services</a>
        </div>
        <div class="footer__col">
          <span class="footer__label">Insights</span>
          <a href="https://www.linkedin.com/newsletters/ai-in-agriculture-7200402923141353472/">LinkedIn Newsletter</a>
          <a href="https://www.youtube.com/@drmarynakuzmenko" target="_blank">YouTube Channel</a>
         <a href="https://moremaryna.com" target="_blank" class="link-highlight-rounded">More Maryna</a>
        </div>
      </div>
    </div>

    <div class="container footer__bottom">
      <div class="footer__copyright">
        © 2026 · <a href="/">{{ site.title }}</a> · <a href="/">{{ site.description }}</a>
      </div>
      <div class="footer__motto italic-text">
        Where Agriculture Meets AI.
      </div>
    </div>
  </footer>
</body>
</html>