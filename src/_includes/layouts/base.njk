<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{{ title or site.title }}</title>
  <meta name="title" content="{{ title or site.title }}">
  <meta name="description" content="{{ description or site.description }}">

  <meta property="og:type" content="website">
  <meta property="og:url" content="https://marynakuzmenko.com/">
  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:image" content="https://marynakuzmenko.com/assets/images/og-card.jpg">

  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:title" content="{{ title or site.title }}">
  <meta property="twitter:description" content="{{ description or site.description }}">

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8SR2ZG841F"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-8SR2ZG841F');
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Dr. Maryna Kuzmenko",
    "jobTitle": "CEO & Founder",
    "worksFor": {
      "@type": "Organization",
      "name": "Petiole"
    },
    "url": "https://marynakuzmenko.com",
    "alumniOf": {
      "@type": "CollegeOrUniversity",
      "name": "Taras Shevchenko National University of Kyiv"
    },
    "knowsAbout": ["Computer Vision", "AgTech", "Public Policy", "AI in Forestry", "Quality Control"],
    "sameAs": [
      "https://www.linkedin.com/in/marynakuzmenko/",
      "https://twitter.com/mary_kuzmenko"
    ],
    "description": "Expert in the strategic deployment of computer vision and AI within the agrifood and forestry sectors."
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body>
  <header class="site-header">
    <div class="header-container">
      <a href="/" class="brand">
       {{ title or site.title }}<span class="dot">.</span>
      </a>

     <input type="checkbox" id="nav-toggle" class="nav-toggle">

         <label for="nav-toggle" class="nav-toggle-label">
           <span></span>
         </label>

         <nav class="nav">
           <a href="/services/">Services</a>
           <a href="/events/">Events</a>
           <a href="/speaking/">Speaking</a>
           <a href="/about/">About</a>
           <a href="/contact/">Contact</a>
         </nav>
       </div>
     </header>

  <main class="main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__brand">
        <div class="brand">Dr. Maryna Kuzmenko</div>
        <p class="footer__tagline">Architecting the future of agrifood through AI, Education, Policy, and Human-First Innovation.</p>
      </div>

      <div class="footer__grid">
        <div class="footer__col">
          <span class="footer__label">Expertise</span>
          <a href="/speaking/">Keynotes & Lectures</a>
          <a href="/events/">Events</a>
          <a href="/services/">Services</a>
        </div>
        <div class="footer__col">
          <span class="footer__label">Insights</span>
                   {% if site.social.linkedin %}<a href="{{ site.social.linkedin }}" aria-label="LinkedIn">LinkedIn</a>{% endif %}
                   {% if site.social.youtube %}<a href="{{ site.social.youtube }}" aria-label="YouTube">YouTube</a>{% endif %}
                   {% if site.social.linkedin %}<a href="{{ site.links.udemy }}" aria-label="Udemy">Udemy</a>{% endif %}
           <a href="https://moremaryna.com" target="_blank">More Maryna</a>
        </div>
      </div>
    </div>

    <div class="container footer__bottom">
      <div class="footer__copyright">
        © 2026 · <a href="/">{{ title or site.title }}</a> · <a href="/">{{ description or site.description }}</a>
      </div>
      <div class="footer__motto italic-text">
        Where Agriculture Meets AI.
      </div>
    </div>
  </footer>
</body>
</html>