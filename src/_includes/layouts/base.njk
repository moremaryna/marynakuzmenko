<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  {# ── Per-page title & description ──────────────────────────────
     `metaTitle` / `metaDescription` are the SEO values (the <title> tag).
     They fall back to the visible `title` / `description`, then to site defaults.
     Set `metaTitle` in a page's front matter to use the long Phase 0 titles
     WITHOUT changing the visible heading/brand. #}
  {% set pageTitle = metaTitle or title or site.title %}
  {% set pageDesc  = metaDescription or description or site.description %}
  {% set canonical = site.url + page.url %}
  {% set pageImage = image or site.image %}

  <title>{{ pageTitle }}</title>
  <meta name="title" content="{{ pageTitle }}">
  <meta name="description" content="{{ pageDesc }}">
  <link rel="canonical" href="{{ canonical }}">

  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDesc }}">
  <meta property="og:image" content="{{ pageImage }}">
  <meta property="og:site_name" content="{{ site.name }}">

  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="{{ canonical }}">
  <meta property="twitter:title" content="{{ pageTitle }}">
  <meta property="twitter:description" content="{{ pageDesc }}">
  <meta property="twitter:image" content="{{ pageImage }}">

  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.google }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analytics.google }}');
  </script>

  {# ── Structured data (schema.org) ──────────────────────────────
     One @graph with three linked nodes:
       • Person  — your entity, stable @id, reused site-wide
       • WebSite — the site, published by the Person
       • WebPage — this specific page, about the Person
     All values are driven from _data/site.json so there is a single
     source of truth and nothing can drift out of sync again. #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "{{ site.url }}/#person",
        "name": {{ site.name | dump | safe }},
        "jobTitle": {{ site.role | dump | safe }},
        "description": {{ site.description | dump | safe }},
        "url": "{{ site.url }}/",
        "image": {{ site.image | dump | safe }},
        "worksFor": { "@type": "Organization", "name": {{ site.worksFor | dump | safe }} },
        "alumniOf": { "@type": "CollegeOrUniversity", "name": {{ site.alumniOf | dump | safe }} },
        "knowsAbout": {{ site.knowsAbout | dump | safe }},
        "award": {{ site.awards | dump | safe }},
        "sameAs": {{ [site.social.linkedin, site.social.youtube, site.social.twitter, site.links.udemy] | dump | safe }}
      },
      {
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": "{{ site.url }}/",
        "name": {{ site.name | dump | safe }},
        "inLanguage": "en",
        "publisher": { "@id": "{{ site.url }}/#person" }
      },
      {
        "@type": "WebPage",
        "@id": "{{ canonical }}#webpage",
        "url": "{{ canonical }}",
        "name": {{ pageTitle | dump | safe }},
        "description": {{ pageDesc | dump | safe }},
        "inLanguage": "en",
        "isPartOf": { "@id": "{{ site.url }}/#website" },
        "about": { "@id": "{{ site.url }}/#person" }
      }
    ]
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body>
  <header class="site-header">
    <div class="header-container">
      <a href="/" class="brand">
       {{ site.name }}<span class="dot">.</span>
      </a>

     <input type="checkbox" id="nav-toggle" class="nav-toggle">

         <label for="nav-toggle" class="nav-toggle-label">
           <span></span>
         </label>

         <nav class="nav">
           <a href="/about/">About</a>
           <a href="/services/">Services</a>
           <a href="/speaking/">Speaking</a>
           <a href="/events/">Events</a>
           <a href="/contact/">Contact</a>
         </nav>
       </div>
     </header>

  <main class="main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__brand">
        <div class="brand">{{ site.name }}</div>
        <p class="footer__tagline">Architecting the future of agrifood through AI, Education, Policy, and Human-First Innovation.</p>
      </div>

      <div class="footer__grid">
        <div class="footer__col">
          <span class="footer__label">Expertise</span>
          <a href="/speaking/">Keynotes & Lectures</a>
          <a href="/ai-in-agriculture/">AI in Agriculture</a>
          <a href="/events/">Events</a>
          <a href="/services/">Services</a>
          <a href="/partner/">Partner With Me</a>
          <a href="/insights/">Insights</a>
          <a href="/recognition/">Recognition</a>
        </div>
        <div class="footer__col">
          <span class="footer__label">Insights</span>
                   {% if site.social.linkedin %}<a href="{{ site.social.linkedin }}" aria-label="LinkedIn">LinkedIn</a>{% endif %}
                   {% if site.social.youtube %}<a href="{{ site.social.youtube }}" aria-label="YouTube">YouTube</a>{% endif %}
                   {% if site.links.udemy %}<a href="{{ site.links.udemy }}" aria-label="Udemy">Udemy</a>{% endif %}
           <a href="https://moremaryna.com" target="_blank" rel="noopener">More Maryna</a>
        </div>
      </div>
    </div>

    <div class="container footer__bottom">
      <div class="footer__copyright">
        © 2026 · <a href="/">{{ site.name }}</a> · {{ site.description }}
      </div>
      <div class="footer__motto italic-text">
        Where Agriculture Meets AI.
      </div>
    </div>
  </footer>
</body>
</html>
